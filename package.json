{
  "name": "react-native-blurred-video",
  "version": "0.2.14",
  "description": "Native GPU-blurred video view for React Native via Nitro Modules",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "cpp",
    "nitrogen",
    "nitro.json",
    "react-native.config.js",
    "react-native-blurred-video.podspec",
    "!**/.DS_Store"
  ],
  "scripts": {
    "nitrogen": "nitrogen",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "nitro",
    "video",
    "blur",
    "avplayer",
    "exoplayer"
  ],
  "repository": "https://github.com/Tonight-App/react-native-video-blur",
  "author": "srivastava9",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "nitrogen": "^0.35.4",
    "react-native-builder-bob": "^0.30.0",
    "react-native-nitro-modules": "^0.35.4",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
